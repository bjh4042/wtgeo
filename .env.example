# 로컬 실행을 위한 환경변수 예시
# 이 파일을 복사해서 `.env` 파일로 만든 뒤 값을 채워주세요.
#   cp .env.example .env

# ===== Supabase (Lovable Cloud 백엔드) =====
# Lovable 프로젝트에서 자동 발급되는 값입니다.
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR-SUPABASE-ANON-KEY"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# ===== Kakao Maps JavaScript SDK =====
# https://developers.kakao.com 에서 앱 등록 후 JavaScript 키를 발급받고,
# [내 애플리케이션 > 플랫폼 > Web]에 `http://localhost:8080` 도메인을 등록하세요.
# 미설정 시 기본 키(배포 도메인 전용)가 사용되어 localhost 에서는 지도 로드가 실패할 수 있습니다.
VITE_KAKAO_API_KEY="YOUR-KAKAO-JAVASCRIPT-KEY"
